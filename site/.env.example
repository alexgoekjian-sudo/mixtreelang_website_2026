# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Google Places API key — used by `npm run reviews:fetch` to pull the latest
# Google reviews snapshot into src/data/google-reviews.json.
# Restrict the key in Google Cloud Console to:
#   - HTTP referrers: localhost, your build runner, mixtreelang.nl
#   - APIs: Places API (New)
GOOGLE_PLACES_API_KEY=
