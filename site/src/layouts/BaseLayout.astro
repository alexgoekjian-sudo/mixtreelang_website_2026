---
/**
 * BaseLayout — owns <head>, header, footer, cookie banner mount.
 * Every page renders through this.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import UtmCapture from '../components/UtmCapture.astro';
import EnhancedConversions from '../components/EnhancedConversions.astro';
import GoogleReviewsBadge from '../components/GoogleReviewsBadge.astro';
import {
  organizationNode,
  websiteNode,
  webPageNode,
  breadcrumbNode,
  meetupEventNode,
} from '../lib/schema';

const GTM_ID = 'GTM-M6N8T8S3';

export interface SEO {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

export interface Props {
  seo: SEO;
  /** Optional structured data objects to inject as JSON-LD <script> tags. */
  jsonLd?: Record<string, unknown>[];
  /** Wrap <main> with a default container. Set false for full-bleed pages. */
  container?: boolean;
  /** Body class for page-scoped styles. */
  bodyClass?: string;
}

const { seo, jsonLd = [], container = true, bodyClass = '' } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://mixtreelang.nl';
const canonical = seo.canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
// Site-wide default OG image (Yoast: og_default_image). Pages can override via seo.ogImage.
const defaultOgImage = `${siteUrl}/og-default.jpg`;
const ogImage = seo.ogImage
  ? new URL(seo.ogImage, siteUrl).toString()
  : defaultOgImage;

// Assemble a single JSON-LD @graph per page.
// Always present: Organization, WebSite, WebPage (this page), BreadcrumbList.
// Page-type nodes (Course, ItemList, BlogPosting, …) come in via `jsonLd`.
// Home additionally carries the recurring conversation meetup Event.
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const graph: Record<string, unknown>[] = [
  organizationNode(),
  websiteNode(),
  webPageNode({
    url: canonical,
    title: seo.title,
    description: seo.description,
    ogImage,
  }),
  breadcrumbNode(canonical),
  ...(isHome ? [meetupEventNode()] : []),
  ...jsonLd,
];
const graphJson = { '@context': 'https://schema.org', '@graph': graph };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Google Search Console verification (from Yoast export) */}
    <meta name="google-site-verification" content="x2YAnunLQITg6BjNOhL4Mda-wXCNbbfbA45jOpb9zy8" />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={canonical} />
    {seo.noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MixTree Languages" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />

    {/* JSON-LD */}
    <script type="application/ld+json" set:html={JSON.stringify(graphJson)} />

    {/* Google Consent Mode v2 + GTM + cookie banner — must load before any other tracking scripts */}
    <CookieBanner />

    {/* Preconnect to commonly used origins */}
    <link rel="preconnect" href="https://cal.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />

    <slot name="head" />
  </head>
  <body class={`min-h-screen bg-white text-slate-800 ${bodyClass}`}>
    {/* GTM noscript fallback */}
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"
      />
    </noscript>
    <Header />
    <Breadcrumbs />
    {container ? (
      <main class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
        <slot />
      </main>
    ) : (
      <main>
        <slot />
      </main>
    )}
    <Footer />
    <GoogleReviewsBadge />
    <UtmCapture />
    <EnhancedConversions />
  </body>
</html>
