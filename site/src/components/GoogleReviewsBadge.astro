---
/**
 * Sticky Google reviews badge — right-edge floating widget.
 *
 * Replicates the WP "google-reviews-pro" badge view: avg rating, star row,
 * review count, "View on Google" link. SSR-only, no third-party JS.
 *
 * Reads from src/data/google-reviews.json.
 */
import data from '../data/google-reviews.json';

const rating = Number(data.rating).toFixed(1);
const reviewCount = data.reviewCount;
const mapsUri = data.mapsUri;
const placeName = data.placeName;
const fullStars = Math.floor(Number(data.rating));
const hasHalf = Number(data.rating) - fullStars >= 0.25 && Number(data.rating) - fullStars < 0.75;
---

<a
  href={mapsUri}
  target="_blank"
  rel="noopener nofollow"
  aria-label={`${placeName} — ${rating} stars on Google, ${reviewCount} reviews. Opens Google Maps.`}
  class="mtl-gbadge group fixed right-3 top-1/2 z-40 hidden -translate-y-1/2 items-center gap-3 rounded-lg border border-slate-200 bg-white py-3 pl-3 pr-4 shadow-lg transition-shadow hover:shadow-xl sm:flex"
>
  <!-- "G" badge (always visible peek) -->
  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white ring-1 ring-slate-200">
    <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.75h3.57c2.08-1.92 3.28-4.74 3.28-8.07z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.75c-.99.66-2.26 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.12A6.997 6.997 0 0 1 5.5 12c0-.74.13-1.45.34-2.12V7.04H2.18A11 11 0 0 0 1 12c0 1.78.43 3.46 1.18 4.96l3.66-2.84z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.04l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/>
    </svg>
  </span>

  <!-- Expanding panel content -->
  <div class="flex flex-col leading-tight">
    <span class="text-xs font-semibold text-slate-700">{placeName}</span>
    <span class="flex items-center gap-1">
      <strong class="text-sm text-slate-900">{rating}</strong>
      <span class="flex text-amber-400" aria-hidden="true">
        {Array.from({ length: 5 }).map((_, i) => {
          if (i < fullStars) return <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 fill-current"><path d="M10 1.5l2.6 5.27 5.82.85-4.21 4.1.99 5.78L10 14.77l-5.2 2.73.99-5.78L1.58 7.62l5.82-.85L10 1.5z"/></svg>;
          if (i === fullStars && hasHalf) return <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 fill-current"><defs><linearGradient id="half"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="#e5e7eb"/></linearGradient></defs><path fill="url(#half)" d="M10 1.5l2.6 5.27 5.82.85-4.21 4.1.99 5.78L10 14.77l-5.2 2.73.99-5.78L1.58 7.62l5.82-.85L10 1.5z"/></svg>;
          return <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 fill-slate-300"><path d="M10 1.5l2.6 5.27 5.82.85-4.21 4.1.99 5.78L10 14.77l-5.2 2.73.99-5.78L1.58 7.62l5.82-.85L10 1.5z"/></svg>;
        })}
      </span>
    </span>
    <span class="text-[11px] text-slate-500">{reviewCount} Google reviews</span>
  </div>
</a>

<style>
  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .mtl-gbadge { transition: none; }
  }
</style>
