---
export interface Props {
  course: {
    slug: string;
    title: string;
    image: string;
    imageAlt: string;
    price: number;
    priceNote?: string;
    format: string;
    levels: string[];
    nextStart: string;
    hours: number;
    duration: string;
  };
}
const { course } = Astro.props;
---
<article class="group flex flex-col overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-200 transition-all duration-200 ease-out hover:-translate-y-1 hover:shadow-xl hover:ring-brand-200 motion-reduce:transition-none motion-reduce:hover:translate-y-0">
  <div class="relative aspect-[16/10] bg-slate-100">
    <img src={course.image} alt={course.imageAlt} class="h-full w-full object-cover" loading="lazy" decoding="async" />
    <div
      class="absolute -bottom-5 right-4 flex h-14 w-14 items-center justify-center rounded-full bg-brand-600 text-white shadow-lg ring-4 ring-white"
      aria-label={`Price: €${course.price}`}
    >
      <span class="whitespace-nowrap text-base font-extrabold leading-none">€{course.price}</span>
    </div>
  </div>
  <div class="flex flex-1 flex-col gap-3 p-5 pt-7">
    {course.priceNote && <p class="text-sm font-medium text-slate-600">{course.priceNote}</p>}
    <h3 class="text-lg font-semibold text-slate-900">{course.title}</h3>
    <p class="text-sm text-slate-600">{course.format}</p>
    <p class="text-sm text-slate-600">Levels: {course.levels.join(', ')}</p>
    <p class="text-sm text-slate-600">Next start date: <strong>{course.nextStart}</strong></p>
    <div class="mt-1 flex items-center gap-4 text-sm text-slate-600">
      <span>⏱ {course.hours} hours</span>
      <span>📅 {course.duration}</span>
    </div>
    <a
      href={course.slug}
      class="mt-auto inline-block rounded-full bg-brand-600 px-4 py-2 text-center text-sm font-semibold text-white hover:bg-brand-700"
      aria-label={`Learn more about ${course.title}`}
    >
      Learn more about {course.title} →
    </a>
  </div>
</article>
