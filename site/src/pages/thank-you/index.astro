---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'Thank You | MixTree Languages',
  description: 'Thanks for contacting MixTree Languages. We will get back to you shortly.',
  noindex: true,
};
---
<BaseLayout seo={seo}>
  <section class="mx-auto max-w-2xl py-16 text-center">
    <h1 class="text-3xl font-bold text-brand-700 sm:text-4xl">Thank you!</h1>
    <p class="mt-4 text-lg text-slate-700">
      Your message has been received. One of our team will get back to you within one working day.
    </p>
    <p class="mt-2 text-slate-600">
      In the meantime, you can <a href="/free-online-english-level-check/" class="text-brand-700 underline">book your free level check</a>
      or browse our <a href="/course-schedule/" class="text-brand-700 underline">course schedule</a>.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-full bg-brand-600 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-700"
      >Back to homepage</a
    >
  </section>
</BaseLayout>
