---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoogleReviews from '../../components/GoogleReviews.astro';

const seo = {
  title: 'Meet Our Teachers | MixTree Languages',
  description:
    'Meet the highly qualified, native and bilingual English teachers at MixTree Languages in Amsterdam. CELTA/TESOL certified with 5+ years of experience.',
};

type Teacher = { name: string; image: string; tagline: string };

// 9 teachers featured on the live site (image filenames mirror /wp-content/uploads/2025/10/).
const teachers: Teacher[] = [
  { name: 'Kathleen', image: '/wp-content/uploads/2025/10/Meet-Kathleen.webp', tagline: 'Founder & Director · CELTA · 15+ years teaching' },
  { name: 'Magui', image: '/wp-content/uploads/2025/10/Meet-Magui-copy.webp', tagline: 'Bilingual teacher · Friendly classroom energy' },
  { name: 'Harbani', image: '/wp-content/uploads/2025/10/Meet-Harbani.webp', tagline: 'Engaging communicator · Loves real-world tasks' },
  { name: 'Ben', image: '/wp-content/uploads/2025/10/Meet-Ben.webp', tagline: 'Calm, patient and full of useful tips' },
  { name: 'Carol', image: '/wp-content/uploads/2025/10/Meet-Carol.webp', tagline: 'Warm and motivating · Loves group dynamics' },
  { name: 'Ashley', image: '/wp-content/uploads/2025/10/Meet-Ashley.webp', tagline: 'Clear explanations · Confidence builder' },
  { name: 'Dale', image: '/wp-content/uploads/2025/10/Meet-Dale.webp', tagline: 'Business English specialist · Pragmatic and direct' },
  { name: 'Claire-Marie', image: '/wp-content/uploads/2025/10/Meet-Claire-Marie.webp', tagline: 'Encouraging coach · Pronunciation expert' },
  { name: 'Jacque', image: '/wp-content/uploads/2025/10/Meet-Jacque.webp', tagline: 'Lively classes · Loves a good discussion' },
];

const SITE = 'https://mixtreelang.nl';
const pageUrl = new URL(Astro.url.pathname, SITE).toString();

// ItemList of Person nodes — helps Google associate teacher names with the school.
const jsonLd = [
  {
    '@type': 'ItemList',
    '@id': `${pageUrl}#teachers`,
    name: 'MixTree Languages teachers',
    numberOfItems: teachers.length,
    itemListElement: teachers.map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Person',
        name: t.name,
        jobTitle: 'English teacher',
        worksFor: { '@id': `${SITE}/#organization` },
        image: `${SITE}${t.image}`,
        description: t.tagline,
      },
    })),
  },
];
---
<BaseLayout seo={seo} jsonLd={jsonLd} container={false}>
  <!-- Hero -->
  <section class="bg-brand-50">
    <div class="mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
      <p class="text-sm font-semibold uppercase tracking-wide text-accent-500">Our Experts</p>
      <h1 class="mt-2 text-3xl font-bold text-brand-700 sm:text-4xl lg:text-5xl">
        Meet our teachers
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-700">
        Our teachers are carefully selected for their qualifications, experience, and ability to motivate
        you — encouraging speaking in class and learning beyond it. With diverse backgrounds and a passion
        for what they do, they bring something special to every lesson.
      </p>
      <p class="mt-3 max-w-3xl text-slate-700">
        All our teachers are <strong>native or bilingual English speakers</strong> and hold a minimum of a
        <strong>CELTA</strong> (or equivalent) certification, with at least <strong>5 years of teaching
        experience</strong> after qualification.
      </p>
    </div>
  </section>

  <!-- Teacher grid -->
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-3">
      {teachers.map((t) => (
        <article class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-200 transition hover:shadow-md">
          <figure class="aspect-square overflow-hidden bg-slate-100">
            <img
              src={t.image}
              alt={`Photo of ${t.name}, English teacher at MixTree Languages`}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </figure>
          <div class="p-4 text-center">
            <h2 class="text-lg font-bold text-brand-700">{t.name}</h2>
            <p class="mt-1 text-sm text-slate-600">{t.tagline}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-brand-50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <GoogleReviews count={3} layout="grid" heading="Read what our students think about us" />
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-700 text-white">
    <div class="mx-auto max-w-3xl px-4 py-14 text-center sm:px-6 lg:px-8 lg:py-16">
      <h2 class="text-2xl font-bold sm:text-3xl">Meet your teacher in person</h2>
      <p class="mx-auto mt-3 max-w-2xl text-white/90">
        Book a free English level check and have a friendly conversation with one of our teachers.
      </p>
      <div class="mt-8">
        <a href="/free-online-english-level-check/" class="rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow hover:brightness-105">
          Book a free level check →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
