---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Private English Lessons — Request a quote | MixTree Languages',
  description:
    'Request your private English lesson package — 10, 20 or 30 hours, online or in person. Tailored to your goals, taught by CELTA-certified teachers in Amsterdam.',
};

const SITE = 'https://mixtreelang.nl';
const pageUrl = new URL(Astro.url.pathname, SITE).toString();
const sent = Astro.url.searchParams.get('sent') === '1';
const presetPackage = Astro.url.searchParams.get('package') ?? '';
const presetFormat = Astro.url.searchParams.get('format') ?? '';

// Service node — non-buyable; treats this as a quote/booking request.
const jsonLd = [
  {
    '@type': 'Service',
    '@id': `${pageUrl}#service`,
    name: 'Private English Lessons',
    serviceType: 'Private language tuition',
    description:
      'One-to-one English lessons online or in person at our Amsterdam school. Packages of 10, 20, or 30 hours, tailored to your goals.',
    provider: { '@id': `${SITE}/#organization` },
    areaServed: ['Amsterdam', 'Netherlands', 'Worldwide (online)'],
    audience: { '@type': 'EducationalAudience', educationalRole: 'student' },
  },
];

const packages = [
  { hours: '10', label: '10 hours', desc: 'Great for a focused goal — interview prep, presentation coaching or a refresher.' },
  { hours: '20', label: '20 hours', desc: 'Most popular — enough time to make real measurable progress on speaking and grammar.' },
  { hours: '30', label: '30 hours', desc: 'Best value — for serious progress towards an exam, role change or relocation.' },
];
---
<BaseLayout seo={seo} jsonLd={jsonLd} container={false}>
  <!-- Hero -->
  <section class="bg-brand-50">
    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:py-16">
      <p class="text-sm font-semibold uppercase tracking-wide text-accent-500">Private English lessons</p>
      <h1 class="mt-2 text-3xl font-bold text-brand-700 sm:text-4xl lg:text-5xl">
        Request your private English lesson package
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-700">
        One-to-one lessons with a CELTA-certified teacher, fully tailored to your goals.
        Choose <strong>10, 20 or 30 hours</strong>, <strong>online or in person</strong> at our
        school in Amsterdam, and we'll send you a quote and the next available start dates within
        one working day.
      </p>
    </div>
  </section>

  {sent && (
    <section class="mx-auto mt-8 max-w-3xl px-4 sm:px-6">
      <div class="rounded-md border border-green-200 bg-green-50 p-4 text-green-800">
        Thanks — your request has been sent. We'll get back to you within one working day.
      </div>
    </section>
  )}

  <!-- Form + sidebar -->
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-3">
      <!-- Form -->
      <form
        action="/mailer.php"
        method="post"
        class="space-y-6 lg:col-span-2"
        data-mtl-form
        data-mtl-conversion="private_lessons_request"
      >
        <input type="hidden" name="form" value="private-lessons" />
        <input type="hidden" name="redirect_to" value="/private-courses/private-english-course/inquiry/?sent=1" />
        {/* Honeypot */}
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
        {/* UTM tracking — populated by UtmCapture script */}
        <input type="hidden" name="utm_source" value="" />
        <input type="hidden" name="utm_medium" value="" />
        <input type="hidden" name="utm_campaign" value="" />
        <input type="hidden" name="utm_term" value="" />
        <input type="hidden" name="utm_content" value="" />
        <input type="hidden" name="traffic_type" value="" />
        <input type="hidden" name="landing_page" value="" />

        <fieldset class="space-y-3">
          <legend class="text-base font-semibold text-brand-700">Choose your package</legend>
          <div class="grid gap-3 sm:grid-cols-3">
            {packages.map((p) => (
              <label class="relative flex cursor-pointer flex-col rounded-xl border border-slate-200 bg-white p-4 shadow-sm has-[:checked]:border-brand-500 has-[:checked]:ring-2 has-[:checked]:ring-brand-200">
                <input
                  type="radio"
                  name="package_hours"
                  value={p.hours}
                  required
                  checked={presetPackage === p.hours}
                  class="peer sr-only"
                />
                <span class="text-lg font-semibold text-brand-700">{p.label}</span>
                <span class="mt-1 text-sm text-slate-600">{p.desc}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <fieldset class="space-y-3">
          <legend class="text-base font-semibold text-brand-700">Where would you like the lessons?</legend>
          <div class="flex flex-wrap gap-3">
            {[
              { value: 'online', label: '💻 Online (video call)' },
              { value: 'in-person', label: '📍 In person at our school in Amsterdam' },
              { value: 'either', label: 'Either / not sure yet' },
            ].map((opt) => (
              <label class="cursor-pointer rounded-full border border-slate-300 bg-white px-4 py-2 text-sm has-[:checked]:border-brand-500 has-[:checked]:bg-brand-50 has-[:checked]:text-brand-700">
                <input
                  type="radio"
                  name="lesson_format"
                  value={opt.value}
                  required
                  checked={presetFormat === opt.value}
                  class="peer sr-only"
                />
                {opt.label}
              </label>
            ))}
          </div>
        </fieldset>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-700">First name *</span>
            <input required name="first-name" type="text" class="w-full rounded border border-slate-300 px-3 py-2 text-sm" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-700">Last name *</span>
            <input required name="last-name" type="text" class="w-full rounded border border-slate-300 px-3 py-2 text-sm" />
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-700">Email *</span>
            <input required name="email" type="email" class="w-full rounded border border-slate-300 px-3 py-2 text-sm" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-700">Phone (optional)</span>
            <input name="phone" type="tel" class="w-full rounded border border-slate-300 px-3 py-2 text-sm" />
          </label>
        </div>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-700">Current English level (if you know it)</span>
          <select name="english_level" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
            <option value="">— Not sure</option>
            <option value="A1">A1 — Beginner</option>
            <option value="A2">A2 — Elementary</option>
            <option value="B1">B1 — Intermediate</option>
            <option value="B2">B2 — Upper-intermediate</option>
            <option value="C1">C1 — Advanced</option>
            <option value="C2">C2 — Proficient</option>
          </select>
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-700">Your goals & preferred schedule *</span>
          <textarea
            required
            name="goals"
            rows="5"
            placeholder="Tell us a little about what you'd like to focus on (e.g. business meetings, IELTS, conversation), and which days/times suit you best."
            class="w-full rounded border border-slate-300 px-3 py-2 text-sm"
          ></textarea>
        </label>

        <label class="flex items-start gap-2 text-sm text-slate-600">
          <input type="checkbox" name="consent" required class="mt-1" />
          <span>
            By submitting this form you accept our
            <a href="/privacy-policy/" class="text-brand-700 underline">privacy policy</a>.
          </span>
        </label>

        <div class="flex flex-wrap items-center gap-4">
          <button
            type="submit"
            class="rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-accent-600"
          >
            Send my request
          </button>
          <p class="text-sm text-slate-500">
            Or email us directly at
            <a href="mailto:info@mixtreelang.nl?subject=Private%20English%20lessons%20%E2%80%94%20quote%20request" class="text-brand-700 underline">info@mixtreelang.nl</a>.
          </p>
        </div>
      </form>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
          <h2 class="text-lg font-semibold text-brand-700">What's included</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-700">
            <li class="flex gap-2"><span class="text-accent-500">✓</span> Free 15-min level check before we start</li>
            <li class="flex gap-2"><span class="text-accent-500">✓</span> Tailored lesson plan based on your goals</li>
            <li class="flex gap-2"><span class="text-accent-500">✓</span> CELTA-certified, native or bilingual teacher</li>
            <li class="flex gap-2"><span class="text-accent-500">✓</span> Materials &amp; homework provided</li>
            <li class="flex gap-2"><span class="text-accent-500">✓</span> Final evaluation &amp; CEFR certificate</li>
          </ul>
        </div>

        <div class="rounded-2xl bg-brand-50 p-6 ring-1 ring-brand-100">
          <h2 class="text-lg font-semibold text-brand-700">Already know your level?</h2>
          <p class="mt-2 text-sm text-slate-700">
            If not, no problem — we'll arrange a free 15-minute level check before you commit.
          </p>
          <a
            href="/free-online-english-level-check/"
            class="mt-4 inline-flex items-center justify-center rounded-full border border-brand-700 bg-white px-4 py-2 text-sm font-semibold text-brand-700 hover:bg-brand-100"
            >Book a free level check</a
          >
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
