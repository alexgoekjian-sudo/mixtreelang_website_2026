---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseCard from '../components/CourseCard.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import HeroVideo from '../components/HeroVideo.astro';
import SectionHeading from '../components/SectionHeading.astro';
import reviewsData from '../data/google-reviews.json';
import { nextStartLabel } from '../lib/schedule';
const reviewsRating = Number(reviewsData.rating).toFixed(1);
const reviewsCount = reviewsData.reviewCount;

const seo = {
  title: 'Learn English in Amsterdam: CELTA-Certified Teachers & Small Group Classes',
  description:
    'MixTree Languages is an English school in central Amsterdam. Small group courses with CELTA-certified teachers since 2015. Find your course today.',
};

const courses = [
  {
    slug: '/english-course/intensive-english-course/',
    title: 'Intensive English Courses',
    image: '/wp-content/uploads/2020/08/intensive-english-courses.jpg',
    imageAlt: 'Students in intensive English language classroom in Amsterdam',
    price: 640,
    priceNote: '€16/h – Book included',
    format: 'In-Person Learning',
    levels: ['A2+', 'B1', 'B2'],
    nextStart: 'MAY 11, 2026',
    hours: 40,
    duration: '4 weeks',
  },
  {
    slug: '/english-course/morning-english-courses/',
    title: 'Morning English Courses',
    image: '/wp-content/uploads/2021/01/morning-english-course.jpg',
    imageAlt: 'Students in morning English class in Amsterdam',
    price: 525,
    priceNote: 'Book included',
    format: 'In-Person Learning',
    levels: ['A2', 'A2+', 'B1', 'B2', 'C1'],
    nextStart: 'MAY 26, 2026',
    hours: 30,
    duration: '6 weeks',
  },
  {
    slug: '/english-course/english-for-beginners/',
    title: 'English for Beginners',
    image: '/wp-content/uploads/2020/02/Interactive-English-courses-Amsterdam.18.jpg',
    imageAlt: 'Beginner English students learning in Amsterdam classroom',
    price: 445,
    priceNote: 'Book included',
    format: 'In-Person Learning',
    levels: ['A1'],
    nextStart: 'MAY 26, 2026',
    hours: 24,
    duration: '6 weeks',
  },
];
---

<BaseLayout seo={seo} container={false}>
  <Fragment slot="head">
    {/* LCP preload \u2014 the YouTube poster is the hero image. */}
    <link
      rel="preload"
      as="image"
      href="https://i.ytimg.com/vi/UII8_Jld4is/hqdefault.jpg"
      fetchpriority="high"
    />
  </Fragment>
  <section class="bg-gradient-to-br from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <h1 class="max-w-3xl text-[1.7rem] font-bold leading-tight text-brand-700 sm:text-3xl lg:text-4xl">
            Learn English in Amsterdam: Expert CELTA-Certified Teachers &amp; Small Group Classes
          </h1>
          <p class="mt-3 flex flex-wrap items-center gap-2 text-sm text-slate-700">
            <span class="text-amber-500" aria-hidden="true">★★★★★</span>
            <strong class="text-slate-900">{reviewsRating}</strong>
            <span class="text-slate-500">· {reviewsCount} Google reviews</span>
          </p>
          <p class="mt-4 max-w-2xl text-lg text-slate-700">
            MixTree Languages is an English language school in central Amsterdam. Since 2015, we've helped students improve English fluency through small group English courses with CELTA-certified teachers.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/english-course/" class="rounded-full bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow hover:bg-brand-700">View Group English Courses →</a>
            <a href="/free-online-english-level-check/" class="rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow hover:brightness-105">Take a Free English Level Check →</a>
          </div>
        </div>
        <div>
          <HeroVideo
            videoId="UII8_Jld4is"
            poster="https://i.ytimg.com/vi/UII8_Jld4is/hqdefault.jpg"
            title="MixTree Languages — Learn English in Amsterdam"
            eager
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <SectionHeading title="Choose Your English Course | In-Person" />
    <p class="mx-auto mt-3 max-w-2xl text-center text-slate-700">
      Small group courses with CELTA-certified teachers at our school in Amsterdam.
    </p>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {courses.map((c) => <CourseCard course={c} />)}
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <SectionHeading
        title="MixTree Languages follows the CEFR"
        subtitle="the Common European Framework of Reference for Languages"
      />
      <figure class="mx-auto mt-3 max-w-3xl">
        <img
          src="/wp-content/uploads/2025/10/MTL-CEFR-Levels.png"
          srcset="/wp-content/uploads/2025/10/MTL-CEFR-Levels-768x261.png 768w, /wp-content/uploads/2025/10/MTL-CEFR-Levels-1024x348.png 1024w, /wp-content/uploads/2025/10/MTL-CEFR-Levels-1200x408.png 1200w"
          sizes="(max-width: 768px) 100vw, 768px"
          width="1754"
          height="596"
          alt="CEFR levels chart from A1 Beginner to C2 Proficient, mapped to MixTree Languages courses"
          loading="lazy"
          decoding="async"
          class="mx-auto h-auto w-full"
        />
      </figure>
    </div>
  </section>

  <section class="bg-brand-50">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <SectionHeading title="Studying English at MixTree Languages | Our approach" />
      <p class="mx-auto mt-4 max-w-3xl text-center text-lg text-slate-700">
        Our English courses are designed with our unique <strong>"Activate Your English"</strong> approach. This method accelerates language learning by prioritising speaking skills. Students actively practice grammar and vocabulary in real-life situations, making the learning process more engaging, practical, and effective.
      </p>
    </div>
  </section>

  <section class="bg-brand-700 text-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold leading-snug sm:text-3xl">
        We believe the <span class="text-accent-300">BEST</span> way to <span class="text-accent-300">LEARN</span> is to <span class="text-accent-300">SPEAK</span> the <span class="text-accent-300">LANGUAGE</span>
      </h2>

      <ul class="mx-auto mt-10 grid max-w-4xl grid-cols-2 gap-4 lg:grid-cols-4">
        {[
          { img: '/wp-content/uploads/2025/10/English-Courses-Amsterdam-activities-2022.3.webp', label: 'Pair Work', alt: 'Two students doing a pair work speaking activity in a small-group English class at MixTree Languages, Amsterdam' },
          { img: '/wp-content/uploads/2020/02/MixTree-Languages-Free-English-level-check-Amsterdam.jpg', label: 'Role Play', alt: 'Students performing a role-play conversation exercise during an English course at MixTree Languages, Amsterdam' },
          { img: '/wp-content/uploads/2018/03/IMG_3375.jpg', label: 'Discussion', alt: 'Group discussion in an English class at MixTree Languages with international students sharing ideas in Amsterdam' },
          { img: '/wp-content/uploads/2025/05/Presentation-MixTree-Languages-Amsterdam-2025.jpg', label: 'Presentations', alt: 'Student giving a presentation in English to classmates and CELTA teacher at MixTree Languages, Amsterdam' },
        ].map((m) => (
          <li class="overflow-hidden rounded-lg bg-white text-slate-800 shadow-md">
            <div class="aspect-[3/2] w-full overflow-hidden bg-slate-100">
              <img src={m.img} alt={m.alt} loading="lazy" decoding="async" class="h-full w-full object-cover" />
            </div>
            <p class="px-4 py-3 text-center font-semibold">{m.label}</p>
          </li>
        ))}
      </ul>

      <h3 class="mt-14 text-center text-xl font-semibold sm:text-2xl">
        But remember <span class="text-accent-300">ALL</span> of the <span class="text-accent-300">skills</span> are important for speaking
      </h3>
      <ul class="mx-auto mt-6 grid max-w-2xl grid-cols-2 gap-3 text-center sm:grid-cols-4">
        {[
          { icon: '📖', label: 'Reading' },
          { icon: '👂', label: 'Listening' },
          { icon: '✍️', label: 'Writing' },
          { icon: '🔤', label: 'Grammar' },
        ].map((s) => (
          <li class="rounded-lg bg-white/10 p-3 ring-1 ring-white/20">
            <div class="text-2xl">{s.icon}</div>
            <p class="mt-1 text-sm font-semibold">{s.label}</p>
          </li>
        ))}
      </ul>

      <p class="mt-12 text-center">
        <a href="/free-online-english-level-check/" class="inline-block rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow hover:brightness-105">
          Start with a Free English Level Check →
        </a>
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <SectionHeading title="Online English with MixTree | Learn from Anywhere" />
    <p class="mx-auto mt-3 max-w-3xl text-center text-slate-700">
      In addition to our in-person courses, we also offer online English group courses for those seeking maximum flexibility — same CELTA-certified teachers, same small groups, joined live from anywhere in the world.
    </p>
    <div class="mx-auto mt-8 max-w-sm">
      <CourseCard course={{
        slug: '/english-course/online-evening-english-courses/',
        title: 'Live-Online Evening English Courses',
        image: '/wp-content/uploads/2020/03/online-live-course-english-teacher.jpg',
        imageAlt: 'Live online English evening course with a CELTA-certified teacher at MixTree Languages',
        price: 385,
        priceNote: 'Book not included in price',
        format: 'On-line Learning',
        levels: ['A2+', 'B1', 'B2', 'C1', 'BUSINESS'],
        nextStart: nextStartLabel({ type: 'EVENING' }, 'Check schedule'),
        hours: 24,
        duration: '6 weeks',
      }} />
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <GoogleReviews count={3} layout="grid" heading="What our students say" />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <SectionHeading title="10 Reasons to Choose MixTree Languages" />
    <ol class="mt-8 grid list-none gap-4 sm:grid-cols-2">
      {[
        ['Highly-qualified teachers', 'every teacher holds a CELTA or TESOL qualification with 10+ years of classroom experience'],
        ['10 years as an English Language school', "after a decade of helping students improve their English we've become one of the best English Language schools in Amsterdam"],
        ['Loved by our students', 'consistently 5-star rated on Google by learners from all over the world'],
        ['Small groups', 'for personalised attention and more speaking time per student'],
        ['All skills covered', 'with a strong focus on speaking and real-world communication'],
        ['Interactive classes with personal language feedback', 'to help you improve faster'],
        ['High-quality materials', 'from the Oxford English File series, plus online self-study practice'],
        ['Certificate of Attendance and Proficiency', 'at the end of your course'],
        ['A friendly and multicultural community', 'with opportunities to socialise and practise English'],
        ['Located in the heart of Amsterdam', 'a welcoming space where you can study, relax, and connect with classmates'],
      ].map(([head, tail], i) => (
        <li class="flex gap-4 rounded-lg border border-slate-200 bg-white p-4">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">{i + 1}</span>
          <p class="text-slate-700"><strong class="text-slate-900">{head}</strong> — {tail}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="bg-brand-700 text-white">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-12 sm:px-6 lg:grid-cols-2 lg:px-8 lg:py-16">
      <figure class="overflow-hidden rounded-xl shadow-lg">
        <img
          src="/wp-content/uploads/2025/10/2.webp"
          srcset="/wp-content/uploads/2025/10/2-300x200.webp 300w, /wp-content/uploads/2025/10/2-370x247.webp 370w, /wp-content/uploads/2025/10/2.webp 600w"
          sizes="(max-width: 1024px) 100vw, 600px"
          width="600"
          height="400"
          alt="International students in a small-group English class at MixTree Languages, Amsterdam"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </figure>
      <div class="text-center lg:text-left">
        <h2 class="text-2xl font-bold sm:text-3xl">Ready to Learn with Others?</h2>
        <p class="mt-3 text-white/90">
          Join a small group, practise English from day one, and meet people from all over the world.
        </p>
        <p class="mt-6">
          <a href="/english-course/" class="inline-block rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow hover:brightness-105">
            View All Group Courses →
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
