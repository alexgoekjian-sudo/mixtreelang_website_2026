# MixTree Languages — Apache configuration

# 1. Force HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Force www → apex (or remove this block if you prefer www)
  RewriteCond %{HTTP_HOST} ^www\.mixtreelang\.nl$ [NC]
  RewriteRule ^ https://mixtreelang.nl%{REQUEST_URI} [R=301,L]

  # Add trailing slash to clean URLs (matches Astro build.format=directory)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-z0-9]+$ [NC]
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [R=301,L]
</IfModule>

# 2. Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# 3. Cache headers
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — never cache (so deploys go live immediately)
  ExpiresByType text/html "access plus 0 seconds"
  Header set Cache-Control "public, max-age=0, must-revalidate" env=HTML

  # Astro fingerprinted assets — 1 year
  <FilesMatch "\.(?:css|js|woff2?|jpg|jpeg|png|gif|webp|avif|svg|ico)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# 4. Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  # Add when ready: Strict-Transport-Security, Content-Security-Policy
</IfModule>

# 5. Custom error pages
ErrorDocument 404 /404.html

# 6. Disallow access to dotfiles
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# 7. Block access to rate-limit dir
<IfModule mod_rewrite.c>
  RewriteRule ^\.rate(/|$) - [F]
</IfModule>
